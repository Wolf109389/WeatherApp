<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeatherApp.MainPage"
             Title="Weather">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Entry Placeholder="Enter city name" Text="{Binding CityName}" />
            <Button Text="Get weather" Command="{Binding SearchLocationShowWeatherAsyncCommand}" />
            <ActivityIndicator />   
            <Label Text="{Binding Temperature}" FontSize="25" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
